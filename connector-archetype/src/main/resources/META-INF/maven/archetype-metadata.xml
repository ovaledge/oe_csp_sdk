<?xml version="1.0" encoding="UTF-8"?>
<archetype-descriptor name="oe-csp-connector-archetype">
    <requiredProperties>
        <requiredProperty key="classPrefix"/>
        <requiredProperty key="sdkVersion">
            <defaultValue>${project.version}</defaultValue>
        </requiredProperty>
    </requiredProperties>
    <fileSets>
        <fileSet filtered="true" encoding="UTF-8">
            <directory></directory>
            <includes>
                <include>pom.xml</include>
                <include>INSTRUCTIONS.txt</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" encoding="UTF-8">
            <directory>src/main/java/com/ovaledge/csp/apps/__artifactId__</directory>
            <includes>
                <include>**/*.java</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" encoding="UTF-8">
            <directory>src/main/resources</directory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" encoding="UTF-8">
            <directory>src/test/java/com/ovaledge/csp/validation</directory>
            <includes>
                <include>**/*.java</include>
            </includes>
        </fileSet>
    </fileSets>
</archetype-descriptor>
